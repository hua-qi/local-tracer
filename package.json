{
  "name": "huaqi-FE-tracer",
  "version": "0.1.0",
  "description": "纯本地 dev 工具：构建期注入运行时埋点，让 Code Agent 看见前端运行时状态",
  "type": "commonjs",
  "license": "MIT",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./vite": {
      "types": "./dist/vite/index.d.ts",
      "require": "./dist/vite/index.js",
      "default": "./dist/vite/index.js"
    },
    "./webpack": {
      "types": "./dist/webpack/index.d.ts",
      "require": "./dist/webpack/index.js",
      "default": "./dist/webpack/index.js"
    },
    "./skill.md": "./skill.md"
  },
  "files": [
    "dist",
    "skill.md",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@babel/generator": "^7.25.0",
    "@babel/parser": "^7.25.0",
    "@babel/traverse": "^7.25.0",
    "@babel/types": "^7.25.0"
  },
  "devDependencies": {
    "@types/babel__generator": "^7.6.8",
    "@types/babel__traverse": "^7.20.6",
    "@types/connect": "^3.4.38",
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0",
    "vitest": "^2.1.0",
    "webpack": "^5.94.0",
    "webpack-dev-server": "^5.1.0"
  },
  "peerDependencies": {
    "vite": "^4.0.0 || ^5.0.0",
    "webpack": "^5.0.0",
    "webpack-dev-server": "^4.0.0 || ^5.0.0"
  },
  "peerDependenciesMeta": {
    "vite": { "optional": true },
    "webpack": { "optional": true },
    "webpack-dev-server": { "optional": true }
  }
}
